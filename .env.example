# Environment variables for the 3D Model Generator

# Meshy.ai API key — get yours at https://www.meshy.ai/
MESHY_API_KEY=your_meshy_api_key_here

# Optional: override the default upload folder (default: uploads/)
# UPLOAD_FOLDER=uploads

# Optional: override the default output folder (default: outputs/)
# OUTPUT_FOLDER=outputs

# Optional: Flask secret key (change for production)
# SECRET_KEY=change-me-in-production
